# ─── SUPABASE ─────────────────────────────────────────────────────────────────
# Project Settings > API no Supabase Dashboard
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Prefixo VITE_ para o frontend React
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Opcional: chave publishable para verificação no diagnóstico
# SUPABASE_PUBLISHABLE_KEY=
# JWKS URL para verificar JWT de utilizadores (dashboard > settings > API)
# SUPABASE_JWKS_URL=

# ─── ANTHROPIC CLAUDE (Geração de Letras) ─────────────────────────────────────
# Obter em: console.anthropic.com/account/keys
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-3-5-sonnet-20241022
CLAUDE_TIMEOUT_MS=60000
CLAUDE_MAX_ATTEMPTS=2

# ─── SUNO API (Geração de Música + Clonagem de Voz) ──────────────────────────
# Obter em: sunoapi.org/api-key
SUNO_API_KEY=
SUNO_TIMEOUT_MS=45000

# ─── BREVO SMTP (Envio de Emails) ─────────────────────────────────────────────
# Obter em: brevo.com > Settings > SMTP & API
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="SeuBeat <noreply@seubeat.ao>"

# ─── AMBIENTE ─────────────────────────────────────────────────────────────────
# URL pública (localhost para desenvolvimento, URL real em produção)
APP_URL="http://localhost:3000"
NODE_ENV=development

# Domínio permitido no CORS (deixar * para desenvolvimento)
ALLOWED_ORIGIN=*
# Timeout para download de áudio (ms)
DOWNLOAD_TIMEOUT_MS=120000
# Activar logs detalhados (1 para activar)
DEBUG=0

# ─── ADMIN ────────────────────────────────────────────────────────────────────
# Emails dos administradores (separados por vírgula)
ADMIN_EMAIL=
# Senha do painel /admin
ADMIN_PASSWORD=
